meta {
  name: Reserve Quantity
  type: http
  seq: 1
}

post {
  url: {{baseURL}}/v1/reservations/quantity
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "event_id": "{{eventID}}",
    "ticket_type_id": "{{ticketTypeID}}",
    "quantity": 2,
    "idempotency_key": "{{idempotencyKey}}"
  }
}
