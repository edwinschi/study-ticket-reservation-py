APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8000
COOKIE_SECURE=false
VISITOR_SESSION_TTL_SECONDS=2592000
RESERVATION_TTL_SECONDS=900
EXPIRATION_WORKER_INTERVAL_SECONDS=5
EXPIRATION_WORKER_BATCH_SIZE=100

POSTGRES_DB=ticket_reservation
POSTGRES_USER=ticket_reservation
POSTGRES_PASSWORD=ticket_reservation

# Docker Compose configures DATABASE_URL and REDIS_URL on the internal network.
